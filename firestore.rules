rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminOrSuperAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          in ['admin', 'superAdmin'];
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superAdmin';
    }

    function isDemo() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'demo';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAdminOrSuperAdmin() || isDemo();
      allow write: if isAdminOrSuperAdmin();
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Assets: admins can CRUD; users can update careCompletions only
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdminOrSuperAdmin();
      allow update: if isAdminOrSuperAdmin();
      allow update: if isAuthenticated() && !isDemo() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['careCompletions', 'updatedAt']);
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdminOrSuperAdmin();
    }

    // Work Orders: all authenticated can read & create; admin can edit/delete
    match /workOrders/{woId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isDemo();
      allow update: if isAdminOrSuperAdmin() ||
        (isAuthenticated() && !isDemo() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']));
      allow delete: if isAdminOrSuperAdmin();
    }

    // IT Tickets: all authenticated can read & create; admin can edit/delete/resolve
    match /itTickets/{ticketId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isDemo();
      allow update, delete: if isAdminOrSuperAdmin();
    }

    // Inventory: all authenticated can read; admin can CRUD; users can update stock counts
    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdminOrSuperAdmin();
      allow update: if isAdminOrSuperAdmin();
      allow update: if isAuthenticated() && !isDemo() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['inStock', 'updatedAt']);
    }

    // Inventory stock logs (subcollection)
    match /inventory/{itemId}/logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isDemo();
      allow update, delete: if isAdminOrSuperAdmin();
    }

    // Facility Map rooms
    match /mapRooms/{roomId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdminOrSuperAdmin();
    }

    // App settings (single document: settings/app)
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Pending users
    match /pendingUsers/{docId} {
      allow read:                    if isAuthenticated();
      allow create, update, delete:  if isAdminOrSuperAdmin();
    }

    // Scheduled Reports: admins manage; Cloud Functions update lastSentAt/nextSendAt
    match /scheduledReports/{reportId} {
      allow read, create, delete: if isAdminOrSuperAdmin();
      allow update: if false; // only Cloud Functions update lastSentAt/nextSendAt
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
